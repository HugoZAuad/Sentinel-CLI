# --- CORE ---
/node_modules
/dist
/build
/out
.externalToolBuilders

# --- NESTJS / TYPESCRIPT ---
*.tsbuildinfo
.nestcli.json

# --- PRISMA ---
# Ignora o arquivo de ambiente, mas NÃO o schema
.env
.env.*
!prisma/schema.prisma
/generated/prisma
/prisma/migrations/*.sql

# --- PUPPETEER / BROWSER ---
# Ignora o cache do navegador que o Puppeteer baixa
.cache
/.local-chromium

# --- REPORTS & OUTPUT ---
# Ignora os PDFs gerados, mas mantém a pasta se houver um .gitkeep
/reports/*.pdf
/reports/*.html
# Caso queira ignorar tudo na pasta reports:
# /reports

# --- LOGS ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- TESTES ---
/coverage
/.nyc_output
.stryker-tmp

# --- IDEs (VS Code, IntelliJ, etc) ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.history/
.project
.settings/
.classpath

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- RUNTIME / TEMP ---
pids
*.pid
*.seed
*.pid.lock
.temp
.tmp
.eslintcache

# --- DIAGNOSTIC REPORTS ---
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json